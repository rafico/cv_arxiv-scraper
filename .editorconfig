# EditorConfig — consistent formatting across editors/agents. https://editorconfig.org
# Ruff (line-length 120, format) remains the source of truth for Python.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
max_line_length = 120

[*.{html,css,js,json,yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # trailing spaces can be meaningful (hard line breaks)

[Makefile]
indent_style = tab
