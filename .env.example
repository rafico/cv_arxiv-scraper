# Optional environment variables for cv_arxiv-scraper.
#
# Copy to `.env` only if you want to set any of these — the app runs fully
# without them. `.env` is gitignored, so your real values stay local.
#
#   cp .env.example .env

# AI summaries / relevance scoring via OpenRouter.
# Only needed if you set `llm.enabled: true` AND `llm.provider: openrouter` in
# config.yaml. A local Ollama provider needs no key. Get one at:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional GitHub token for repo enrichment (stars/license). Raises the API rate
# limit from 60 to 5000 requests/hour. A classic token with no scopes is enough.
GITHUB_TOKEN=

# Optional fixed Flask session secret. If unset, a random one is generated and
# cached at instance/.flask_secret on first run.
SECRET_KEY=
